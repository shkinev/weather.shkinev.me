# --- Развёртывание (только в env) ---
WEATHER_DB_PATH=/data/weather.sqlite3
LOG_DIR=/logs
WEB_BIND_PORT=18080
WEATHER_TIMEZONE=Asia/Omsk

# --- Секреты (только в env) ---
TELEGRAM_BOT_TOKEN=

# Учётка для /admin/* (HTTP Basic Auth).
# Можно задать ИЛИ ADMIN_PASSWORD (открытым текстом — хешируется в памяти на старте),
# ИЛИ заранее посчитанный ADMIN_PASSWORD_HASH (bcrypt).
# Сгенерировать хэш: python -c "import bcrypt; print(bcrypt.hashpw(b'mypass', bcrypt.gensalt()).decode())"
# Если не задано — admin-страницы отключены.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_PASSWORD_HASH=

# --- Безопасность ingest (POST /api/ingest) ---
# Опциональный shared-secret. Если задан — клиент шлёт его в заголовке X-Ingest-Token.
INGEST_TOKEN=
# Лимит размера тела запроса (байт), max устройств в одном payload и датчиков на устройство.
INGEST_MAX_BODY_BYTES=524288
INGEST_MAX_DEVICES=5
INGEST_MAX_SENSORS_PER_DEVICE=128

# --- Первичный seed для app_settings (только если БД пустая) ---
# После первого запуска эти значения переезжают в БД (таблица app_settings) и
# редактируются из /admin/settings. Менять здесь после первого старта смысла нет —
# приоритет имеет БД.
WEATHER_SITE_URL=https://weather.example.com
APP_TITLE=Weather Station
SITE_BRAND=Weather Dashboard
WEATHER_PLACE_NAME=Моя станция
YANDEX_METRIKA_ID=

TELEGRAM_ADMIN_IDS=
TELEGRAM_DAILY_USER_IDS=
TELEGRAM_DAILY_TIMES=07:00,20:00
TELEGRAM_STALE_MINUTES=10
TELEGRAM_MONITOR_INTERVAL_SECONDS=120

TELEGRAM_DYNAMIC_NAME_ENABLED=1
TELEGRAM_DYNAMIC_NAME_PREFIX=
TELEGRAM_DYNAMIC_NAME_INTERVAL_MINUTES=30

# Если включено — неизвестные mac автоматически создают запись station (disabled).
# Безопаснее держать выключенным и регистрировать станции вручную через /admin/stations.
AUTO_REGISTER_STATIONS=0
